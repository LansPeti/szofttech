        <mxCell id="-coN81oQd0SVzrDMktg3-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#36393d;fillColor=#ffcc99;align=left;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;Person 1&lt;/font&gt;&lt;/b&gt;:&amp;nbsp;&lt;div&gt;Gertrúd, 41 éves nő, 3 gyermekes anyuka&lt;div&gt;&lt;b&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;Pain point&lt;/font&gt;&lt;/b&gt;:&lt;/div&gt;&lt;div&gt;&amp;nbsp;túl sok eseménye van és a naptárban nem eléggé tudja megkülönböztetni, hogy melyik milyen csoportba tartozik&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;Megoldás&lt;/font&gt;&lt;/b&gt;:&amp;nbsp;&lt;/div&gt;&lt;div&gt;Esemény színének kiválasztása, több szín lehetőség&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="360" x="240" y="17" as="geometry" />
        </mxCell>
        <mxCell id="-coN81oQd0SVzrDMktg3-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#36393d;fillColor=#ffff88;align=left;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 13px;&quot;&gt;&lt;b&gt;Person &lt;/b&gt;&lt;/font&gt;&lt;b&gt;2&lt;/b&gt;:&amp;nbsp;&lt;div&gt;Tamás, 19 éves orvostan hallgató&lt;div&gt;&lt;b&gt;Pain point&lt;/b&gt;:&lt;/div&gt;&lt;div&gt;&amp;nbsp;nem szeretné egyesével beírni a tanóráit, mégis szeretné látni mikor van lukasórája&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;font&gt;Megoldás&lt;/font&gt;&lt;/b&gt;:&amp;nbsp;&lt;/div&gt;&lt;div&gt;Naptárak megosztása, az egyetem megosztja a Neptun naptárát, amit Tamás elfogad és rögtön látja az adatokat&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="360" x="240" y="130" as="geometry" />
        </mxCell>
        <mxCell id="-coN81oQd0SVzrDMktg3-4" parent="1" style="text;html=1;whiteSpace=wrap;fillColor=#cdeb8b;align=left;verticalAlign=middle;rounded=0;strokeColor=#36393d;" value="&lt;b&gt;Person 3&lt;/b&gt;:&lt;div&gt;Piroska, 33 éves projektmenedzser&lt;div&gt;&lt;b&gt;Pain point&lt;/b&gt;:&lt;/div&gt;&lt;div&gt;szereti a naptárában vezetni a meetingjeinek jegyzeteit, amik nagyon hosszúak és részletesek lehetnek&lt;/div&gt;&lt;div&gt;&lt;b&gt;Megoldás&lt;/b&gt;:&lt;/div&gt;&lt;div&gt;jegyzet csatolása az eseményekhez&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="360" x="240" y="260" as="geometry" />
        </mxCell>
